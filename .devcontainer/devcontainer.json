{
    "name": "Antigravity Airflow Dev",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "mounts": [
        "source=${localEnv:HOME}/.config/gcloud,target=/home/vscode/.config/gcloud,type=bind,consistency=cached",
        "source=${localEnv:HOME}/.dbt,target=/home/vscode/.dbt,type=bind,consistency=cached"
    ],
    "workspaceFolder": "/home/vscode/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/vscode/workspace,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "innoverio.vscode-dbt-power-user",
                "mtxr.sqltools"
            ]
        }
    },
    "forwardPorts": [
        8080
    ],
    "containerEnv": {
        "AIRFLOW__API__PORT": "8080",
        "AIRFLOW__CORE__DAGS_FOLDER": "/home/vscode/workspace/dags",
        "AIRFLOW__COSMOS__ENABLE_TELEMETRY": "False",
        "AIRFLOW__LOGGING__LOG_LEVEL": "DEBUG",
        "AIRFLOW__CORE__LOGGING_LEVEL": "DEBUG",
        "PYTHONASYNCIODEBUG": "1",
        "AIRFLOW__CORE__LOAD_EXAMPLES": "False"
    },
    "postStartCommand": "/usr/local/bin/setup-airflow.sh",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
        },
        "ghcr.io/devcontainers/features/github-cli:1": { "version": "latest"},
        "ghcr.io/devcontainers/features/gcloud:1": { "version": "latest" }
    }
}